# ─── DocMind Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in your values before deploying.
# Never commit .env to GitHub.

# AWS region to deploy into
AWS_REGION=ap-south-1

# These are auto-generated by deploy.sh — fill in after first deploy
API_BASE_URL=https://YOUR_API_ID.execute-api.ap-south-1.amazonaws.com/prod
UPLOAD_BUCKET_NAME=docmind-uploads-YOUR_ACCOUNT_ID
FRONTEND_BUCKET_NAME=docmind-frontend-YOUR_ACCOUNT_ID
DYNAMODB_TABLE_NAME=docmind-documents
